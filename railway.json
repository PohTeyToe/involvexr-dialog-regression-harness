{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd python && pip install -e ."
  },
  "deploy": {
    "startCommand": "cd python && uvicorn dialog_harness_api.main:app --host 0.0.0.0 --port $PORT",
    "healthcheckPath": "/healthz",
    "restartPolicyType": "ON_FAILURE"
  }
}
